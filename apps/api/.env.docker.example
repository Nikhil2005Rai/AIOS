# AI OS Production Environment Configuration for nikhilrai.me

# App Basics
ENVIRONMENT=production
LOG_LEVEL=INFO

# Security Secrets (Generate random strings for production!)
BETTER_AUTH_SECRET=generate-a-secure-random-secret-here
ENCRYPTION_KEYS=generate-a-32-byte-hex-key-here

# Database (Handled automatically by Docker Compose using container name 'db')
DATABASE_URL=postgresql+psycopg://ai_os_user:ai_os_password@db:5432/ai_os

# LLM Fallback Settings
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash
LLM_API_KEY=your-fallback-gemini-api-key

# Upstash Redis (For job queues & summarization cache)
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Frontend URL (For CORS - Matches your custom Vercel domain)
FRONTEND_ORIGIN=https://archimedes.nikhilrai.me
